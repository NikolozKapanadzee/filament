created:
    - database/factories/ConfrenceFactory.php
    - database/factories/VenueFactory.php
    - database/factories/SpeakerFactory.php
    - database/factories/TalkFactory.php
    - database/migrations/2026_07_03_214934_create_confrences_table.php
    - database/migrations/2026_07_03_214935_create_venues_table.php
    - database/migrations/2026_07_03_214936_create_speakers_table.php
    - database/migrations/2026_07_03_214937_create_talks_table.php
    - database/migrations/2026_07_03_214938_create_confrence_speaker_table.php
    - database/migrations/2026_07_03_214939_create_confrence_talk_table.php
    - app/Models/Confrence.php
    - app/Models/Venue.php
    - app/Models/Speaker.php
    - app/Models/Talk.php
models:
    User: { name: string, email: string, email_verified_at: 'datetime nullable', password: string, remember_token: 'string nullable' }
    Confrence: { name: string, description: string, start_date: datetime, end_date: datetime, status: string, region: string, venue_id: 'unsignedInteger nullable', relationships: { belongsTo: Venue, belongsToMany: 'Speaker, Talk' } }
    Venue: { name: string, city: string, country: string, postal_code: string, relationships: { hasMany: Confrence } }
    Speaker: { name: string, email: string, bio: text, twitter_handle: string, relationships: { belongsToMany: Confrence } }
    Talk: { title: string, abstract: text, speaker_id: unsignedInteger, relationships: { belongsTo: Speaker, belongsToMany: Confrence } }
